# HubSpot Private App Access Token
# Create one at: Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.companies.read,
#   crm.objects.deals.read, crm.objects.line_items.read, crm.schemas.custom.read,
#   crm.objects.owners.read, sales-email-read
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional
HUBSPOT_PORTAL_ID=
HUBSPOT_RATE_LIMIT=100
HUBSPOT_SCHEMA_CACHE_TTL=86400
HUBSPOT_QUERY_CACHE_TTL=300
