# HubSpot OAuth 2.0 public app credentials
# Register a public app at https://developers.hubspot.com (Apps → Create app).
# - Set the redirect URL on the app to: http://localhost:8976/callback
# - Select these read scopes: crm.objects.contacts.read, crm.objects.companies.read,
#   crm.objects.deals.read, crm.objects.line_items.read, crm.schemas.custom.read,
#   crm.objects.owners.read, sales-email-read, oauth
# - Install the app to a HubSpot account
# First run will open a browser to complete authorization; tokens are cached
# under ~/.hubspot_revops/tokens.json and refreshed silently thereafter.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Optional: override the local callback port (must match the redirect URL on your app)
# HUBSPOT_REDIRECT_PORT=8976

# Advanced / CI escape hatch: skip OAuth entirely by providing a static token
# (Private App token or a pre-minted OAuth access token). When set, this takes
# precedence over the OAuth flow above.
# HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional
HUBSPOT_PORTAL_ID=
HUBSPOT_RATE_LIMIT=100
HUBSPOT_SCHEMA_CACHE_TTL=86400
HUBSPOT_QUERY_CACHE_TTL=300
